{
  "name": "@bbv/nestjs-pagination",
  "version": "0.0.1",
  "description": "NestJS pagination utilities with Swagger support",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:cov": "jest --coverage --passWithNoTests",
    "test:watch": "jest --watch",
    "clean": "rm -rf dist coverage"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/swagger": "^7.0.0"
  },
  "dependencies": {
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1"
  },
  "devDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/swagger": "^7.0.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "reflect-metadata": "^0.2.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BlackBoxVision/nestjs-plugins.git",
    "directory": "packages/nestjs-pagination"
