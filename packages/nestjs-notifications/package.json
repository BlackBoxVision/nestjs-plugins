{
  "name": "@bbv/nestjs-notifications",
  "version": "0.0.1",
  "description": "NestJS multi-channel notification module (email, in-app, SMS)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "prisma"],
  "scripts": {
    "build": "tsc && cp -r src/templates/defaults dist/templates/",
    "dev": "tsc --watch",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:cov": "jest --coverage --passWithNoTests",
    "test:watch": "jest --watch",
    "clean": "rm -rf dist coverage"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/bullmq": "^10.0.0",
    "@prisma/client": "^5.0.0 || ^6.0.0",
    "bullmq": "^5.0.0",
    "@nestjs/event-emitter": "^2.0.0 || ^3.0.0",
    "firebase-admin": "^12.0.0 || ^13.0.0",
    "@nestjs/swagger": "^7.0.0",
    "@bbv/nestjs-pagination": "^0.0.1"
  },
  "peerDependenciesMeta": {
    "@nestjs/event-emitter": {
      "optional": true
    },
    "firebase-admin": {
      "optional": true
    },
    "@nestjs/swagger": {
      "optional": true
    },
    "@bbv/nestjs-pagination": {
      "optional": true
    }
  },
  "dependencies": {
    "nodemailer": "^6.9.0",
    "handlebars": "^4.7.0",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1"
  },
  "devDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/bullmq": "^10.2.0",
    "@nestjs/testing": "^10.0.0",
    "@prisma/client": "^6.0.0",
    "@nestjs/event-emitter": "^2.1.0",
    "@types/jest": "^29.5.0",
    "@types/nodemailer": "^6.4.14",
    "bullmq": "^5.0.0",
    "firebase-admin": "^13.0.0",
    "jest": "^29.7.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BlackBoxVision/nestjs-plugins.git",
    "directory": "packages/nestjs-notifications"
  }
}
