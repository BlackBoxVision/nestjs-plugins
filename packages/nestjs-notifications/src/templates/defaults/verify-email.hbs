<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Verify Your Email</title>
</head>
<body style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;">
  <h1 style="color: #333;">Verify Your Email Address</h1>
  <p style="color: #555; font-size: 16px; line-height: 1.5;">
    Please confirm your email address by clicking the button below.
  </p>
  <p style="margin-top: 24px;">
    <a href="{{verifyUrl}}" style="background-color: #4CAF50; color: white; padding: 12px 24px; text-decoration: none; border-radius: 4px; display: inline-block;">
      Verify Email
    </a>
  </p>
  <p style="color: #555; font-size: 14px; margin-top: 16px;">
    If you cannot click the button, copy and paste this URL into your browser:
    <br>
    <a href="{{verifyUrl}}" style="color: #4CAF50;">{{verifyUrl}}</a>
  </p>
  <p style="color: #999; font-size: 12px; margin-top: 32px;">
    If you did not create an account, please ignore this email.
  </p>
</body>
</html>
