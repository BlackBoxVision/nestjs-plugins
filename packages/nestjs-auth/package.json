{
  "name": "@bbv/nestjs-auth",
  "version": "0.0.1",
  "description": "NestJS auth module with social login, organizations, and RBAC",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "prisma"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:cov": "jest --coverage --passWithNoTests",
    "test:watch": "jest --watch",
    "clean": "rm -rf dist coverage"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/event-emitter": "^2.0.0 || ^3.0.0",
    "@nestjs/passport": "^10.0.0",
    "@prisma/client": "^5.0.0 || ^6.0.0",
    "passport": "^0.7.0",
    "@bbv/nestjs-otp": "^0.0.1",
    "@nestjs/swagger": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/event-emitter": {
      "optional": true
    },
    "@bbv/nestjs-otp": {
      "optional": true
    },
    "@nestjs/swagger": {
      "optional": true
    }
  },
  "dependencies": {
    "@nestjs/jwt": "^10.2.0",
    "bcryptjs": "^2.4.3",
    "passport-jwt": "^4.0.1",
    "passport-google-oauth20": "^2.0.0",
    "passport-local": "^1.0.0",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1"
  },
  "devDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@prisma/client": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@nestjs/event-emitter": "^2.1.0",
    "@types/jest": "^29.5.0",
    "@types/passport-google-oauth20": "^2.0.14",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "jest": "^29.7.0",
    "passport": "^0.7.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BlackBoxVision/nestjs-plugins.git",
    "directory": "packages/nestjs-auth"
  }
}
